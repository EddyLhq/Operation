# GoDaddy API Credentials
# Get them from https://developer.godaddy.com/keys
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Slack Webhook URL
SLACK_WEBHOOK_URL=

# Set to True for Production, False for OTE (Test environment)
GODADDY_PRODUCTION=True

# 是否开启 A 记录子域名查询 (True/False)
ENABLE_A_RECORD_QUERY=False

# 自动检查间隔（秒）。如果设置，脚本将循环运行。
# 86400 为 24 小时，3600 为 1 小时。
CHECK_INTERVAL=86400
